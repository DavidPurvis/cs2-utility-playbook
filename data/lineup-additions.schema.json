{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lineup additions",
  "type": "object",
  "required": ["lineups"],
  "properties": {
    "lineups": {
      "type": "array",
      "items": { "$ref": "#/definitions/lineup" }
    }
  },
  "definitions": {
    "setpos": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": { "type": "number" },
          "description": "Exact in-game setpos values: [x, y] or [x, y, z]"
        },
        {
          "type": "object",
          "required": ["source", "x", "y"],
          "properties": {
            "source": { "const": "percent" },
            "x": { "type": "number", "minimum": 0, "maximum": 100 },
            "y": { "type": "number", "minimum": 0, "maximum": 100 }
          },
          "description": "cs2util-style radar percent (0-100). Less precise than setpos."
        }
      ]
    },
    "lineup": {
      "type": "object",
      "required": ["id", "map", "name", "util", "side", "area", "throwPos", "landingPos", "throw", "source"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "map": { "enum": ["ancient", "anubis", "cache", "dust2", "inferno", "mirage", "nuke", "overpass"] },
        "name": { "type": "string", "minLength": 3 },
        "util": { "enum": ["SMOKE", "FLASH", "MOLLY", "HE"] },
        "side": { "enum": ["T", "CT"] },
        "area": { "type": "string", "minLength": 1 },
        "throwPos": { "$ref": "#/definitions/setpos" },
        "landingPos": { "$ref": "#/definitions/setpos" },
        "throw": { "enum": ["LMB", "JT", "WJT", "RMB", "RUN", "WALK2"] },
        "mustLearn": { "type": "boolean" },
        "instant": { "type": "boolean" },
        "purpose": { "type": "string" },
        "stand": { "type": "string" },
        "aim": { "type": "string" },
        "notes": { "type": "string" },
        "video": { "type": "string", "format": "uri" },
        "screenshots": {
          "type": "object",
          "properties": {
            "stand": { "type": "string", "format": "uri" },
            "aim": { "type": "string", "format": "uri" },
            "result": { "type": "string", "format": "uri" }
          }
        },
        "source": {
          "type": "object",
          "required": ["name", "url"],
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    }
  }
}
